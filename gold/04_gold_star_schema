# CELL 11 -- Final Gold validation summary
# =============================================================================
# Purpose : Recap all 9 Gold tables in one place -- row count, key nulls,
#           duplicates. Final evidence that the Star Schema is clean and
#           ready for BI consumption.
# =============================================================================

GOLD_TABLES = [
    {"table": "gold.dim_date",     "key": "date_key"},
    {"table": "gold.dim_customer", "key": "customer_id"},
    {"table": "gold.dim_product",  "key": "product_id"},
    {"table": "gold.dim_employee", "key": "emp_id"},
    {"table": "gold.dim_supplier", "key": "supplier_id"},
    {"table": "gold.dim_shipper",  "key": "shipper_id"},
    {"table": "gold.dim_division", "key": "division_id"},
    {"table": "gold.fact_sales",   "key": ["order_id", "line_no"]},
    {"table": "gold.fact_budget",  "key": ["office", "employee_id", "year"]},
]

summary_rows = []

for t in GOLD_TABLES:
    key_cols = [t["key"]] if isinstance(t["key"], str) else t["key"]
    df = spark.table(t["table"])

    total = df.count()

    null_condition = None
    for k in key_cols:
        cond = F.col(k).isNull()
        null_condition = cond if null_condition is None else (null_condition | cond)
    nulls = df.filter(null_condition).count()

    dupes = df.groupBy(*key_cols).count().filter("count > 1").count()

    summary_rows.append({
        "table": t["table"],
        "rows": total,
        "key_nulls": nulls,
        "duplicate_keys": dupes,
        "status": "CLEAN" if (nulls == 0 and dupes == 0) else "REVIEW NEEDED"
    })

print(f"{'='*90}")
print(f"  GOLD STAR SCHEMA -- FINAL VALIDATION SUMMARY")
print(f"{'='*90}")
print(f"  {'Table':<22} {'Rows':>10} {'Key Nulls':>10} {'Dup Keys':>10}  Status")
print(f"  {'-'*22} {'-'*10} {'-'*10} {'-'*10}  {'-'*15}")
for r in summary_rows:
    print(f"  {r['table']:<22} {r['rows']:>10,} {r['key_nulls']:>10} {r['duplicate_keys']:>10}  {r['status']}")

issues = sum(1 for r in summary_rows if r["status"] != "CLEAN")
print(f"\n{'='*90}")
if issues == 0:
    print(f"  \u2705 All {len(summary_rows)} Gold tables are clean and ready for BI consumption.")
else:
    print(f"  \u26a0\ufe0f  {issues} table(s) need review -- see above.")
print(f"{'='*90}")
