# CELL 9 -- gold.fact_sales
# =============================================================================
# Purpose : The central fact table. Grain: one row per order line item
#           (order_id, line_no).
#
# Join justification (each one earns its place, not "join everything"):
#   - Order_Details is the base: quantity/unit_price/discount already live
#     here, so extended_amount needs NO join, pure row-level calculation.
#   - Orders: joined for order_date/customer_id/employee_id -- attributes
#     that live on the parent order, needed as FKs/dates on the fact.
#   - Shipments: joined for shipper_id + corrected shipment_date ONLY.
#     Confirmed via EDA to share the exact same grain (order_id, line_no)
#     as Order_Details 1:1 -- this is fact-to-fact consolidation of a
#     single business event split across two source files, not a
#     dimension join. Shipments' own customer_id/employee_id/product_id
#     columns are intentionally ignored (redundant, avoid two sources of
#     truth). LEFT JOIN to avoid silently dropping order lines if the 1:1
#     grain match ever breaks in a future load.
#   - dim_product: joined ONLY to bring unit_cost for the margin
#     calculation -- pre-computed here (not left to Power BI DAX) since
#     DAX measures like SUMX+RELATED scale poorly at this row volume;
#     margin is materialized as a column instead.
# =============================================================================

def build_fact_sales():
    df_details = spark.table("silver.fact_order_details")

    df_orders = spark.table("silver.fact_orders").select(
        col("order_id"),
        col("order_date"),
        col("customer_id"),
        col("employee_id"),
    )

    df_shipments = spark.table("silver.fact_shipments").select(
        col("order_id"),
        col("line_no"),
        col("shipper_id"),
        col("shipment_date"),
    )

    df_product_cost = spark.table("gold.dim_product").select(
        col("product_id"),
        col("unit_cost"),
    )

    df_fact_sales = (
        df_details
        .join(df_orders, on="order_id", how="left")
        .join(df_shipments, on=["order_id", "line_no"], how="left")
        .join(df_product_cost, on="product_id", how="left")
    )

    df_fact_sales = df_fact_sales.withColumn(
        "extended_amount",
        F.round(col("quantity") * col("unit_price") * (F.lit(1) - col("discount")), 2)
    ).withColumn(
        "margin",
        F.round(
            (col("quantity") * col("unit_price") * (F.lit(1) - col("discount")))
            - (col("quantity") * col("unit_cost")),
            2
        )
    )

    df_fact_sales = df_fact_sales.select(
        col("order_id"),
        col("line_no"),
        col("order_date"),
        col("shipment_date"),
        col("customer_id"),
        col("employee_id"),
        col("product_id"),
        col("shipper_id"),
        col("quantity"),
        col("unit_price"),
        col("discount"),
        col("extended_amount"),
        col("margin"),
    )

