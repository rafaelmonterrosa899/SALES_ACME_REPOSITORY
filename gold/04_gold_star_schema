# CELL 4 -- gold.dim_date
# =============================================================================
# Purpose : Generate a standard calendar dimension covering DATE_RANGE_START
#           to DATE_RANGE_END. Not sourced from any file -- required for
#           YTD vs LY YTD comparisons (business bonus question) and general
#           time-based drill-down (Year -> Quarter -> Month -> Day).
# =============================================================================

def build_dim_date():
    df_dates = spark.sql(f"""
        SELECT explode(sequence(
            to_date('{DATE_RANGE_START}'),
            to_date('{DATE_RANGE_END}'),
            interval 1 day
        )) AS full_date
    """)

    df_dim_date = df_dates.select(
        date_format(col("full_date"), "yyyyMMdd").cast("int").alias("date_key"),
        col("full_date"),
        year(col("full_date")).alias("year"),
        quarter(col("full_date")).alias("quarter"),
        month(col("full_date")).alias("month"),
        date_format(col("full_date"), "MMMM").alias("month_name"),
        dayofmonth(col("full_date")).alias("day_of_month"),
        dayofweek(col("full_date")).alias("day_of_week"),
        date_format(col("full_date"), "EEEE").alias("day_name"),
        weekofyear(col("full_date")).alias("week_of_year"),
        # day_of_year used to compare YTD windows consistently (e.g.
        # "all dates where day_of_year <= today's day_of_year" for
        # YTD vs LY YTD comparisons)
        date_format(col("full_date"), "D").cast("int").alias("day_of_year"),
    )

    print(f"dim_date rows: {df_dim_date.count():,} "
          f"(covering {DATE_RANGE_START} to {DATE_RANGE_END})")

    return df_dim_date


