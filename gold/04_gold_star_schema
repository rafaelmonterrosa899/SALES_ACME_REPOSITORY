def build_fact_budget():
    df = spark.table("silver.fact_budget")

    # Same lean-metadata pattern as the rest of Gold: drop Silver's own
    # created_at/updated_at/row_hash, keep only source_system, and let
    # write_gold_merge() generate Gold's own created_at/updated_at.
    cols_to_drop = [
        "created_at", "updated_at", "row_hash",
        "bronze_source_file_name", "bronze_created_at", "bronze_updated_at"
    ]
    df = df.drop(*[c for c in cols_to_drop if c in df.columns])
    print(f"fact_budget rows: {df.count():,}")
    return df


